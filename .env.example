# ApiXS — Environment Configuration
# Copy this file to .env and fill in your values.

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get API_ID and API_HASH from https://my.telegram.org/apps
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# Bot token from @BotFather (for bot mode or notifications)
TELEGRAM_BOT_TOKEN=your_bot_token

# Numeric bot ID (from @userinfobot or @RawDataBot)
TELEGRAM_BOT_ID=0

# Comma-separated Telegram user IDs allowed to use the userbot
ALLOWED_USERS=123456789

# ── Database ──────────────────────────────────────────────────────────────────
# MySQL connection URL
DATABASE_URL=mysql://user:password@localhost:3306/your_database

# Separate DB for anti-delete logs (optional, falls back to DATABASE_URL)
AD_DATABASE_URL=mysql://user:password@localhost:3306/your_database

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SESSION_ENC_KEY=your_fernet_key_here

# ── Groq AI ───────────────────────────────────────────────────────────────────
# Free API key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# ── Web Dashboard ─────────────────────────────────────────────────────────────
# Public URL of your status site
STATUS_EXTERNAL_URL=https://YOUR_DOMAIN

# Internal URL for bot→web communication (e.g. in Docker: http://web:5000)
STATUS_INTERNAL_URL=http://localhost:5000

# Flask session secret — generate a random string
FLASK_SECRET_KEY=change-me-to-a-random-secret

# ── Commands ──────────────────────────────────────────────────────────────────
COMMAND_PREFIX=.axs

# ── Anti-Delete ───────────────────────────────────────────────────────────────
# Channel ID where media backups are stored (bot must be admin)
ANTI_DELETE_MEDIA_CHANNEL=

# ── Yandex Music ──────────────────────────────────────────────────────────────
# OAuth token for Yandex Music (.ynow command)
YANDEX_MUSIC_TOKEN=

# ── Video Downloader ──────────────────────────────────────────────────────────
# Base64-encoded cookies.txt for YouTube bot-check bypass
# PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("cookies.txt")) | clip
DL_COOKIES_B64=

# Local path to cookies.txt (alternative to DL_COOKIES_B64)
DL_COOKIES_FILE=

# ── Misc ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
WHISPER_MODEL=whisper-large-v3-turbo
